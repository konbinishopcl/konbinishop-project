PORT=3333

# Clave compartida con el frontend — si está vacía el guard se deshabilita (dev local)
API_KEY=

# MySQL
DATABASE_URL="mysql://user:password@127.0.0.1:3306/konbini"

# Secreto para firmar los JWT
JWT_SECRET="change-me"

# Google OAuth — Client ID de la Google Cloud Console
GOOGLE_CLIENT_ID=

# Heroes & spots — per-day price (CLP), global active quota and max run length (days)
HERO_PRICE_PER_DAY=15000
HERO_MAX_ACTIVE=5
HERO_MAX_DAYS=30
SPOT_PRICE_PER_DAY=8000
SPOT_MAX_ACTIVE=10
SPOT_MAX_DAYS=30

# Events — max run length (days); price per day comes from category.pricePerDay
EVENT_MAX_DAYS=60

# Redis — cache HTTP (GET público, TTL 1 día, invalidación por colección)
REDIS_URL=redis://localhost:6379

# URLs
API_BASE_URL=https://api.tudominio.cl
FRONTEND_URL=https://tudominio.cl


# Mailgun — envío de emails transaccionales
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_FROM="Konbini <no-reply@tudominio.cl>"

# Formulario de contacto — destinatarios de notificación (separados por coma)
CONTACT_NOTIFY_EMAILS=admin@tudominio.cl

# Transbank WebPay Plus
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TRANSBANK_ENV=sandbox
