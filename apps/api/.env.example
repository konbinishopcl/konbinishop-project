PORT=3333

# Neon (https://console.neon.tech/) — copiar desde "Connection Details"
# Pooled connection (host con -pooler): la usa la app
DATABASE_URL="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/konbini?sslmode=require"
# Direct connection (sin -pooler): la usan las migraciones de Prisma
DIRECT_URL="postgresql://USER:PASS@ep-xxxx.sa-east-1.aws.neon.tech/konbini?sslmode=require"
