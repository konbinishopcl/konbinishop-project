// Prisma schema — modelos exportados desde Strapi (konbini-api).
// Usuarios y autenticación se delegan a Neon Auth: no hay modelo User aquí.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Geografía ───────────────────────────

model Region {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  communes  Commune[]
  events    Event[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Commune {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  region    Region?  @relation(fields: [regionId], references: [id])
  regionId  Int?
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
}

// ─────────────────────────── Taxonomía ───────────────────────────

model Category {
  id          Int      @id @default(autoincrement())
  name        String?
  slug        String   @unique
  description String?
  events      Event[]
  heroes      Hero[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─────────────────────────── Contenido ───────────────────────────

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String   @db.Text
  image     String? // URL de imagen (Strapi media)
  tags      Tag[]
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A paid placement shown in the home hero carousel. Works like a Spot
// (per-day pricing, global quota) but renders in the home hero instead of
// the ad grid. Created by any authenticated user; active right away.
model Hero {
  id          Int          @id @default(autoincrement())
  title       String // first headline line (white in the design)
  titleAccent String? // second headline line (accent/orange in the design)
  lead        String? // short description shown under the title
  image       String // URL
  date      DateTime?    @db.Date // optional date label shown in the hero
  place     String? // optional place label shown in the hero
  linkType  SpotLinkType // CTA link — same kinds as a Spot
  linkValue String

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  // Owner — any authenticated user can create a hero.
  owner  User @relation("HeroOwner", fields: [userId], references: [id])
  userId Int

  // Billing: charged per day. amount = days * HERO_PRICE_PER_DAY (env).
  days           Int
  amount         Int
  expirationDate DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
}

// A paid ad shown among the event cards. No detail view: it is an image and/or a
// title, and its link points to a URL, a phone number or an email.
enum SpotLinkType {
  URL
  PHONE
  EMAIL
}

model Spot {
  id             Int          @id @default(autoincrement())
  title          String
  image          String? // URL
  linkType       SpotLinkType
  linkValue      String // a URL, a phone number or an email, per linkType
  expirationDate DateTime?    @db.Date

  // Owner — any authenticated user can create a spot.
  owner  User @relation("SpotOwner", fields: [userId], references: [id])
  userId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Event {
  id             Int      @id @default(autoincrement())
  title          String
  company        String?
  slug           String   @unique
  description    String   @db.Text
  about          String?  @db.Text
  expirationDate DateTime? @db.Date
  address        String
  addressNumber  String
  ticketUrl      String?

  // Media (URLs)
  banner  String?
  poster  String?
  gallery String[]

  // Moderación
  isApproved     Boolean @default(false)
  isRejected     Boolean @default(false)
  rejectedReason String? // corregido desde el typo de Strapi "rejected_reazon"

  // Usuario organizador + moderadores (sistema de usuarios local)
  owner        User?   @relation("EventOwner", fields: [userId], references: [id])
  userId       Int?
  approvedBy   User?   @relation("EventApprover", fields: [approvedById], references: [id])
  approvedById Int? // corregido: Strapi lo modelaba como oneToMany
  rejectedBy   User?   @relation("EventRejecter", fields: [rejectedById], references: [id])
  rejectedById Int?

  // Relaciones
  region     Region?    @relation(fields: [regionId], references: [id])
  regionId   Int?
  commune    Commune?   @relation(fields: [communeId], references: [id])
  communeId  Int?
  categories Category[]
  articles   Article[]

  // Componentes (repetibles en Strapi → tablas propias)
  prices      EventPrice[]
  dates       EventDate[]
  socialLinks EventSocialLink[]
  videos      EventVideo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([regionId])
  @@index([communeId])
  @@index([userId])
  @@index([approvedById])
  @@index([rejectedById])
}

// ───────────────────── Componentes de Event ──────────────────────

model EventPrice {
  id      Int    @id @default(autoincrement())
  name    String
  price   Int    @default(0)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

model EventDate {
  id        Int       @id @default(autoincrement())
  date      DateTime? @db.Date
  startTime String? // Strapi "time" → "HH:mm"
  endTime   String?
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int

  @@index([eventId])
}

model EventSocialLink {
  id      Int     @id @default(autoincrement())
  link    String?
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

model EventVideo {
  id      Int     @id @default(autoincrement())
  link    String?
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

// ──────────────────────────── Usuarios ───────────────────────────
// Sistema de usuarios local (reemplaza a Neon Auth).

enum Role {
  SUPER_ADMIN
  ADMIN
  AUTHENTICATED
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String
  firstname    String?
  lastname     String?
  rut          String?
  isCompany    Boolean @default(false)
  role         Role    @default(AUTHENTICATED)
  confirmed    Boolean @default(false)
  blocked      Boolean @default(false)

  // Recuperación de contraseña: hash SHA-256 del token + su expiración.
  resetToken       String?
  resetTokenExpiry DateTime?

  events         Event[] @relation("EventOwner")
  approvedEvents Event[] @relation("EventApprover")
  rejectedEvents Event[] @relation("EventRejecter")
  spots          Spot[]  @relation("SpotOwner")
  heroes         Hero[]  @relation("HeroOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
