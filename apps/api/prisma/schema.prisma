// Prisma schema — modelos exportados desde Strapi (konbini-api).
// Usuarios y autenticación se delegan a Neon Auth: no hay modelo User aquí.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" para local; "rhel-openssl-3.0.x" para el runtime de Vercel Functions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime: conexión pooled de Neon (host con "-pooler").
  url       = env("DATABASE_URL")
  // Migraciones: conexión directa de Neon (host sin "-pooler").
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Geografía ───────────────────────────

model Country {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  states    State[]
  profiles  Profile[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model State {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  country   Country  @relation(fields: [countryId], references: [id])
  countryId Int
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
}

model City {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  state     State    @relation(fields: [stateId], references: [id])
  stateId   Int
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stateId])
}

// ─────────────────────────── Taxonomía ───────────────────────────

// ─── Taxonomías separadas (Phase 18) ─── (legacy Category/Tag eliminados en 18-04)

model EventCategory {
  id          Int      @id @default(autoincrement())
  name        String?
  slug        String   @unique
  description String?
  pricePerDay Int      @default(1000)
  icon        String?
  color       String?
  minDays     Int      @default(1)
  maxDays     Int      @default(30)
  order       Int      @default(0)
  events      Event[]
  heroes      Hero[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("event_categories")
}

model EventTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event_tags")
}

model ArticleCategory {
  id          Int       @id @default(autoincrement())
  name        String?
  nameJa      String?
  slug        String    @unique
  description String?
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("article_categories")
}

model ArticleTag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("article_tags")
}

// ─────────────────────────── Contenido ───────────────────────────

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String   @db.Text
  image      String?
  youtubeUrl String?
  status       PublicationStatus @default(DRAFT)
  statusReason String?
  owner        User?             @relation("ArticleOwner", fields: [userId], references: [id])
  userId       Int?
  articleCategories ArticleCategory[]
  articleTags       ArticleTag[]
  articleImages     ArticleImage[]
  events    Event[]
  likes     Like[]
  orderItems   OrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ArticleImage {
  id        Int     @id @default(autoincrement())
  url       String
  order     Int     @default(0)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  @@index([articleId])
  @@map("article_images")
}

// ── Estado de publicación unificado para Event, Spot y Hero ──────

enum PublicationStatus {
  DRAFT              // creado, aún sin pagar
  PENDING_PAYMENT    // en carrito, esperando pago
  PENDING_MODERATION // pagado, esperando revisión del admin
  APPROVED           // visible públicamente
  REJECTED           // rechazado antes de publicarse
  BANNED             // baneado después de estar publicado
}

// A paid placement shown in the home hero carousel. Works like a Spot
// (per-day pricing, global quota) but renders in the home hero instead of
// the ad grid. Created by any authenticated user; active right away.
model Hero {
  id          Int          @id @default(autoincrement())
  title       String // first headline line (white in the design)
  titleAccent String? // second headline line (accent/orange in the design)
  lead        String? // short description shown under the title
  image       String // URL
  date      DateTime?    @db.Date // optional date label shown in the hero
  place     String? // optional place label shown in the hero
  link      String?  // CTA URL

  eventCategory   EventCategory? @relation(fields: [eventCategoryId], references: [id])
  eventCategoryId Int?

  // Owner — any authenticated user can create a hero.
  owner      User        @relation("HeroOwner", fields: [userId], references: [id])
  userId     Int
  orderItems OrderItem[]

  // Billing: set at payment confirmation. amount = days * HERO_PRICE_PER_DAY (env).
  days           Int?
  amount         Int?
  expirationDate DateTime? @db.Date

  status       PublicationStatus @default(DRAFT)
  statusReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([eventCategoryId])
}

// A paid ad shown among the event cards. No detail view: it is an image and/or a
// title, and its link points to a URL, a phone number or an email.
enum SpotLinkType {
  URL
  PHONE
  EMAIL
}

model Spot {
  id             Int          @id @default(autoincrement())
  title          String
  image          String? // URL
  linkType       SpotLinkType
  linkValue      String // a URL, a phone number or an email, per linkType

  // Billing: set at payment confirmation.
  days           Int?
  amount         Int?
  expirationDate DateTime?    @db.Date

  status       PublicationStatus @default(DRAFT)
  statusReason String?

  // Owner — any authenticated user can create a spot.
  owner      User        @relation("SpotOwner", fields: [userId], references: [id])
  userId     Int
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Event {
  id             Int      @id @default(autoincrement())
  title          String
  company        String?
  slug           String   @unique
  description    String   @db.Text
  about          String?  @db.Text
  expirationDate DateTime? @db.Date
  address        String
  addressNumber  String?
  ticketUrl      String?

  // Media (URLs)
  banner  String?
  poster  String?
  gallery Json     @default("[]")

  // Moderación
  status         PublicationStatus @default(DRAFT)
  rejectedReason String?

  // Usuario organizador + moderadores (sistema de usuarios local)
  owner        User?   @relation("EventOwner", fields: [userId], references: [id])
  userId       Int?
  approvedBy   User?   @relation("EventApprover", fields: [approvedById], references: [id])
  approvedById Int? // corregido: Strapi lo modelaba como oneToMany
  rejectedBy   User?   @relation("EventRejecter", fields: [rejectedById], references: [id])
  rejectedById Int?

  // Relaciones
  city       City?      @relation(fields: [cityId], references: [id])
  cityId     Int?
  eventCategory   EventCategory? @relation(fields: [eventCategoryId], references: [id])
  eventCategoryId Int?
  eventTags       EventTag[]
  articles   Article[]

  // Componentes (repetibles en Strapi → tablas propias)
  prices      EventPrice[]
  dates       EventDate[]
  socialLinks EventSocialLink[]
  videos      EventVideo[]
  orderItems  OrderItem[]
  likes       Like[]
  savedBy     SavedEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cityId])
  @@index([userId])
  @@index([approvedById])
  @@index([rejectedById])
  @@index([eventCategoryId])
}

// ───────────────────── Componentes de Event ──────────────────────

model EventPrice {
  id      Int    @id @default(autoincrement())
  name    String
  price   Int    @default(0)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

model EventDate {
  id        Int       @id @default(autoincrement())
  date      DateTime? @db.Date
  startTime String? // Strapi "time" → "HH:mm"
  endTime   String?
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int

  @@index([eventId])
}

model EventSocialLink {
  id      Int     @id @default(autoincrement())
  link    String?
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

model EventVideo {
  id      Int     @id @default(autoincrement())
  link    String?
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  @@index([eventId])
}

// ──────────────────────────── Órdenes ────────────────────────────

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FAILED
  CANCELLED
}

enum OrderItemType {
  EVENT
  SPOT
  HERO
  ARTICLE
  SUBSCRIPTION
}

model Order {
  id         Int         @id @default(autoincrement())
  status     OrderStatus @default(DRAFT)
  total      Int         @default(0)
  gateway    String?     // pasarela usada: TRANSBANK, FLOW, etc.
  externalId String?     // token o ID de transacción devuelto por la pasarela
  owner      User        @relation("UserOrders", fields: [userId], references: [id])
  userId     Int
  // v2: contexto de organización al pagar (carrito de la org en vez de la persona).
  // FK apunta a User con type=ORGANIZATION — validación en service layer (Pitfall #6).
  org        User?       @relation("OrgOrders", fields: [orgId], references: [id])
  orgId      Int?
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([orgId])
}

model OrderItem {
  id        Int           @id @default(autoincrement())
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int
  type      OrderItemType
  days      Int
  unitPrice Int           // precio por día congelado al agregar al carrito
  subtotal  Int           // days * unitPrice

  event   Event? @relation(fields: [eventId], references: [id])
  eventId Int?
  spot    Spot?  @relation(fields: [spotId], references: [id])
  spotId  Int?
  hero    Hero?  @relation(fields: [heroId], references: [id])
  heroId  Int?
  article Article? @relation(fields: [articleId], references: [id])
  articleId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, type]) // un ítem por tipo por orden
  @@index([orderId])
  @@index([eventId])
  @@index([spotId])
  @@index([heroId])
  @@index([articleId])
}

// ──────────────────────────── Usuarios ───────────────────────────
// Sistema de usuarios local (reemplaza a Neon Auth).

enum UserType {
  PERSON
  ORGANIZATION
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AUTHENTICATED
}

enum OrgRole {
  OWNER
  MEMBER
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String?
  googleId     String? @unique
  firstname    String?
  lastname     String?
  rut          String?
  isCompany    Boolean @default(false)
  role         Role    @default(AUTHENTICATED)
  confirmed    Boolean @default(false)
  blocked      Boolean @default(false)

  // v2: tipo de cuenta — PERSON con credenciales; ORGANIZATION sin login propio
  type            UserType  @default(PERSON)
  // v2: identificador público único global (personas y orgs comparten namespace)
  handle          String?   @unique
  // v2: badge Verificado — asignado/revocado solo por SUPER_ADMIN
  isVerified      Boolean   @default(false)
  // v2: 2FA por email — código de 6 dígitos + expiración (10 min recomendado)
  twoFactorCode   String?
  twoFactorExpiry DateTime?

  // Recuperación de contraseña: hash SHA-256 del token + su expiración.
  resetToken       String?
  resetTokenExpiry DateTime?

  // v2: cambio de email — pendingEmail es el email nuevo a confirmar, token SHA-256, expira 24h
  pendingEmail            String?
  emailChangeToken        String?
  emailChangeTokenExpiry  DateTime?

  events         Event[] @relation("EventOwner")
  approvedEvents Event[] @relation("EventApprover")
  rejectedEvents Event[] @relation("EventRejecter")
  spots          Spot[]  @relation("SpotOwner")
  heroes         Hero[]  @relation("HeroOwner")
  orders         Order[] @relation("UserOrders")
  orgOrders      Order[] @relation("OrgOrders")
  articles       Article[] @relation("ArticleOwner")
  likes          Like[]
  profile        Profile?

  // v2 Organizaciones — relaciones inversas
  memberships    OrgMember[]     @relation("UserMemberships")  // orgs a las que este user pertenece
  orgMembers     OrgMember[]     @relation("OrgMembers")        // miembros de este user si es ORGANIZATION
  orgInvitations OrgInvitation[] @relation("OrgInvitations")    // invitaciones emitidas por este user si es ORGANIZATION

  // v2 Core systems — relaciones inversas
  notifications     Notification[] @relation("UserNotifications")
  orgNotifications  Notification[] @relation("OrgNotifications")
  savedEvents       SavedEvent[]
  subscription      Subscription?  @relation("UserSubscription")
  orgSubscription   Subscription?  @relation("OrgSubscription")
  transfersFrom     Transfer[]     @relation("TransferFrom")
  transfersTo       Transfer[]     @relation("TransferTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────── Perfiles ───────────────────────────

model Profile {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  displayName String?
  bio         String? @db.Text
  avatar      String?
  banner      String?
  website     String?

  // Redes sociales
  instagram   String?
  tiktok      String?
  facebook    String?
  x           String?
  youtube     String?
  twitch      String?
  linkedin    String?

  // País del usuario (elegido durante el registro)
  country   Country? @relation(fields: [countryId], references: [id])
  countryId Int?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────── Documentos legales ─────────────────────────

enum LegalDocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
}

model LegalDocument {
  id        Int               @id @default(autoincrement())
  type      LegalDocumentType @unique
  content   String            @db.Text
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ──────────────────────── Preguntas frecuentes ───────────────────────

model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────── Formulario de contacto ─────────────────────

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────── Newsletter ──────────────────────────

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ───────────────────────────── Likes ─────────────────────────────

model Like {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int?

  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@unique([userId, articleId])
  @@index([eventId])
  @@index([articleId])
}

// ─────────────────────── Auditoría ───────────────────────
// Registro de acciones de admins y usuarios sobre las entidades del sistema.
// userId es Int? SIN relación FK: así un usuario eliminado no borra su historial
// de auditoría (cumplimiento / trazabilidad). El join con User, si se necesita el
// email del actor, se hace manualmente en el endpoint de consulta.

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  BAN
  UNBAN
}

// Nombres comerciales del producto: AVISO = Spot, PORTADA = Hero.
// El enum usa los nombres de marca por decisión de producto (D-Phase7).
enum AuditEntity {
  EVENT
  USER
  AVISO
  PORTADA
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  userId    Int?        // actor; null si la acción es de sistema o el usuario fue eliminado
  action    AuditAction
  entity    AuditEntity
  entityId  Int
  metadata  Json        @default("{}")
  ip        String?     // dato personal (Ley 21.719) — retención 24 meses
  userAgent String?     // dato personal (Ley 21.719) — retención 24 meses
  url       String?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([entity, action, createdAt])
  @@map("audit_logs")
}

// ─────────────────────── Organizaciones ──────────────────────────
// Membresía explícita entre un User PERSON (userId) y un User ORGANIZATION (orgId).
// El constraint user.type = 'ORGANIZATION' para orgId se enforza en service layer
// (MySQL no soporta CHECK sobre campos de tablas relacionadas). Patrón polymorphic
// self-referencial: ambos lados de la relación apuntan a User vía nombres distintos.

model OrgMember {
  userId    Int
  orgId     Int
  role      OrgRole  @default(MEMBER)
  user      User     @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  org       User     @relation("OrgMembers",      fields: [orgId],  references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

model OrgInvitation {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  orgId     Int
  org       User     @relation("OrgInvitations", fields: [orgId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([token])
}

// ─────────────────────────── v2 Core systems ────────────────────────────

enum NotificationType {
  EVENT_APPROVED
  EVENT_REJECTED
  EVENT_BANNED
  SPOT_APPROVED
  SPOT_REJECTED
  SPOT_BANNED
  HERO_APPROVED
  HERO_REJECTED
  HERO_BANNED
  ARTICLE_APPROVED
  ARTICLE_REJECTED
  ARTICLE_BANNED
  ORG_INVITATION
  TRANSFER_REQUEST
  TRANSFER_ACCEPTED
  TRANSFER_REJECTED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELLED
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED      // cancelada pero vigente hasta fin de ciclo
  EXPIRED        // ciclo terminado sin renovación
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  AUTO_ACCEPTED  // creada por OWNER de la org destino → no requiere aprobación
  ADMIN_FORCED   // forzada por admin
}

enum TransferItemType {
  EVENT
  SPOT
  HERO
  ARTICLE
}

// Tabla key-value para configuración del sistema (precios, cupos, créditos).
// Cast a número/boolean se hace en el service layer. El seeder mantiene los defaults.
// En Phase 8 esta tabla EXISTE pero el código de aplicación sigue leyendo
// de env vars hasta que Phase 11 los migre a leer de Settings.
model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Mensaje interno generado automáticamente por el sistema.
// El destinatario puede ser un user PERSON (userId) o una org (orgId).
// Exactamente uno de userId / orgId debe estar presente — validado en service layer.
model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  title     String
  body      String?          @db.Text
  payload   Json             @default("{}")    // datos extra (ej: eventId, fromUserId)
  read      Boolean          @default(false)

  user      User?            @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  userId    Int?
  org       User?            @relation("OrgNotifications",  fields: [orgId],  references: [id], onDelete: Cascade)
  orgId     Int?

  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([orgId, read])
  @@index([createdAt])
}

// Favoritos de eventos — un user puede guardar muchos eventos, sin duplicados.
model SavedEvent {
  userId    Int
  eventId   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

// Suscripción mensual. Puede pertenecer a un user PERSON o a una org (XOR).
// creditsUsed se resetea al inicio de cada ciclo; no se acumulan.
model Subscription {
  id              Int                @id @default(autoincrement())
  status          SubscriptionStatus @default(ACTIVE)

  user            User?              @relation("UserSubscription", fields: [userId], references: [id], onDelete: Cascade)
  userId          Int?               @unique  // máximo una sub activa por user
  org             User?              @relation("OrgSubscription",  fields: [orgId],  references: [id], onDelete: Cascade)
  orgId           Int?               @unique  // máximo una sub activa por org

  cycleStart      DateTime
  cycleEnd        DateTime
  creditsUsed     Int                @default(0)
  creditsTotal    Int                @default(10)  // copiado desde Settings.SUBSCRIPTION_CREDITS al activar

  cancelledAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([cycleEnd])
}

// Transferencia polymorphic de un ítem (Event/Spot/Hero/Article) entre cuentas.
// No hay FKs múltiples al ítem — itemType + itemId; la validación de existencia
// se hace en service layer (patrón replicado de AuditLog).
model Transfer {
  id          Int              @id @default(autoincrement())
  itemType    TransferItemType
  itemId      Int

  fromUser    User             @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  fromUserId  Int
  toOrg       User             @relation("TransferTo",   fields: [toOrgId],    references: [id], onDelete: Cascade)
  toOrgId     Int

  status      TransferStatus   @default(PENDING)
  reason      String?          // motivo si REJECTED
  resolvedBy  Int?             // userId del OWNER que aceptó/rechazó, o admin
  resolvedAt  DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([toOrgId, status])
  @@index([fromUserId])
  @@index([itemType, itemId])
}

// ─────────────────────────── v2 Servicios y CRM ──────────────────────

enum ServiceType {
  PHOTOGRAPHY
  CONTENT
}

enum CrmType {
  CONTACT
  PHOTOGRAPHY
  CONTENT
}

enum CrmStage {
  NEW
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

// Opción de servicio (checkbox del formulario público de fotografía o content-creators).
// CRUD en /services/photography/options y /services/content-creators/options (admin).
model ServiceOption {
  id        Int              @id @default(autoincrement())
  type      ServiceType
  label     String
  active    Boolean          @default(true)
  order     Int              @default(0)
  requests  ServiceRequest[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type, active])
}

// Solicitud pública de cotización (sin auth requerida).
// Al crearse, el service layer de Phase 14 también creará una CrmEntry asociada
// vía sourceType + sourceId. Las opciones marcadas en el form son many-to-many.
model ServiceRequest {
  id          Int             @id @default(autoincrement())
  type        ServiceType
  name        String
  email       String
  eventName   String?
  eventDate   DateTime?       @db.Date
  eventPlace  String?
  options     ServiceOption[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type, createdAt])
}

// Pipeline CRM unificado para Contacto, Fotografía y Creadores de contenido.
// Patrón polymorphic: sourceType + sourceId apuntan a ContactMessage (CONTACT)
// o a ServiceRequest (PHOTOGRAPHY|CONTENT). Sin FKs múltiples — la validación
// de que sourceId existe en la tabla correspondiente se hace en el service layer
// (patrón replicado de AuditLog y Transfer).
//
// Decisión locked KEY #2: CrmEntry es un modelo independiente. ContactMessage
// SE MANTIENE SIN CAMBIOS para backwards compatibility con el endpoint /contact
// ya existente. Al recibir POST /contact, Phase 14 creará el ContactMessage + un
// CrmEntry con sourceType=CONTACT, sourceId=contactMessage.id.
model CrmEntry {
  id          Int       @id @default(autoincrement())
  type        CrmType
  stage       CrmStage  @default(NEW)
  stageReason String?               // requerido si stage=LOST (validación service layer)

  // Polymorphic source — apunta a ContactMessage o ServiceRequest según `type`.
  sourceType  CrmType                // duplica `type` para queries directas por origen
  sourceId    Int                    // id en la tabla correspondiente

  // Snapshot de datos de contacto (denormalizado para listados rápidos del kanban)
  contactName  String
  contactEmail String

  assignedTo   Int?                  // userId del admin asignado (opcional)
  notes        CrmNote[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([stage, type])
  @@index([sourceType, sourceId])
  @@index([assignedTo])
  @@index([createdAt])
}

// Nota interna del equipo comercial sobre una entrada de CRM.
// El autor es el userId del admin que la escribió (puede ser null si el admin se eliminó).
model CrmNote {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  authorId   Int?                                                   // userId del admin (null si eliminado)
  crmEntry   CrmEntry @relation(fields: [crmEntryId], references: [id], onDelete: Cascade)
  crmEntryId Int
  createdAt  DateTime @default(now())

  @@index([crmEntryId, createdAt])
  @@index([authorId])
}
