# Strapi Configuration
NEXT_PUBLIC_WEB_URL=http://dev.konbini.cl
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cookie names for authentication
NEXT_PUBLIC_STRAPI_TOKEN_COOKIE=strapi_jwt
NEXT_PUBLIC_STRAPI_USER_COOKIE=strapi_user

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_BASE_URL=https://res.cloudinary.com

# Google reCAPTCHA v3
NEXT_PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Optional: Custom Strapi URL for production
# NEXT_PUBLIC_STRAPI_URL=https://your-strapi-instance.com
