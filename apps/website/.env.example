# URL interna del backend — usada server-side (SSR / Server Components)
API_URL=http://localhost:3333/api

# Clave compartida con el backend — solo server-side, nunca llega al browser
API_KEY=

# Origen del backend para URLs de imágenes (/uploads) — sí es público (no es un secreto)
NEXT_PUBLIC_API_ORIGIN=http://localhost:3333

# Bloqueo de indexación SEO mientras el sitio no está listo.
# "true"  → robots.txt disallow:/ + meta noindex/nofollow en todo el sitio.
# "false" o ausente → indexación normal (SEO activo). Server-side, no NEXT_PUBLIC.
BLOCK_INDEXING=false

# Google OAuth — Client ID de la Google Cloud Console (público, puede ir al browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Redes sociales y contacto (público — se usa en componentes del cliente)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/konbinishop.cl
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@konbinishop.cl
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/konbinishop
NEXT_PUBLIC_INSTAGRAM_FOLLOWERS=244K
NEXT_PUBLIC_INSTAGRAM_HANDLE=@konbinishop.cl
NEXT_PUBLIC_CONTACT_EMAIL=hola@konbini.cl
NEXT_PUBLIC_ABUSE_EMAIL=abuso@konbini.cl
NEXT_PUBLIC_PRIVACY_EMAIL=privacidad@konbini.cl
