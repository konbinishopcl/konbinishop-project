# Konbini Listing - Variables de Entorno
# Copia este archivo a .env y configura los valores según tu entorno

# API Configuration
API_URL=http://localhost:1337

# Google Tag Manager
GTM_ID=GTM-XXXXXXXX

# Search Engine Control
BLOCK_SEARCH_ENGINES=false

# Server Configuration (opcional, usado por PM2)
NITRO_PORT=4000

# Environment
NODE_ENV=development
