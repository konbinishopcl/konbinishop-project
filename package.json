{
  "name": "konbini-project",
  "version": "1.0.0",
  "private": true,
  "description": "Konbini monorepo",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "fuser -k 3000/tcp 3001/tcp 3333/tcp 24678/tcp 1337/tcp 2>/dev/null; sleep 1 && turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start --parallel",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "multer": "^2.2.0",
      "undici": "^6.27.0"
    }
  }
}
