{
  "name": "konbini-project",
  "version": "1.0.0",
  "private": true,
  "description": "Konbini monorepo",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "lsof -ti:24678,1337,3000,3001,3333 | xargs kill -9 2>/dev/null; sleep 1 && turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start --parallel",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "pnpm": {
    "overrides": {
      "pinia": "2.3.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "prisma",
      "sharp"
    ]
  }
}
