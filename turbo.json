{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": [".nuxt/**", "dist/**", ".output/**", ".next/**"],
      "env": [
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
        "NEXT_PUBLIC_SITE_URL",
        "API_URL",
        "API_KEY"
      ],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    }
  }
}
